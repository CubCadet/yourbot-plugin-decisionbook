{
  "pages": [
    {
      "id": "overview",
      "title": "DecisionBook Overview",
      "permission": "manager",
      "widgets": [
        {
          "id": "onboarding",
          "type": "markdown",
          "title": "Quick start",
          "rpc_method": "dashboard.get_onboarding",
          "width": "full"
        },
        {
          "id": "storage_health",
          "type": "alert",
          "title": "Ledger health",
          "rpc_method": "dashboard.get_storage_health",
          "width": "full"
        },
        {
          "id": "total_decisions",
          "type": "stat_card",
          "title": "Total decisions",
          "rpc_method": "dashboard.get_total_decisions",
          "width": "third"
        },
        {
          "id": "open_decisions",
          "type": "stat_card",
          "title": "Open decisions",
          "rpc_method": "dashboard.get_open_decisions",
          "width": "third"
        },
        {
          "id": "closed_decisions",
          "type": "stat_card",
          "title": "Closed decisions",
          "rpc_method": "dashboard.get_closed_decisions",
          "width": "third"
        },
        {
          "id": "recent_decisions",
          "type": "table",
          "title": "Recent decisions",
          "rpc_method": "dashboard.get_recent_decisions",
          "width": "full",
          "columns": [
            {"key": "id", "label": "ID"},
            {"key": "status", "label": "Status"},
            {"key": "summary", "label": "Decision"},
            {"key": "recorded", "label": "Recorded"},
            {"key": "closed", "label": "Closed"}
          ]
        }
      ]
    }
  ]
}
